{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "COMM interface",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#method-declaration"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.documentation.comm-interface",
          "match": "//[!/].*$"
        },
        {
          "name": "comment.line.double-slash.comm-interface",
          "match": "//.*$"
        }
      ]
    },
    "method-declaration": {
      "patterns": [
        {
          "name": "meta.function.comm-interface",
          "match": "\\b(method)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.statement-kind.comm-interface"
            },
            "2": {
              "name": "entity.name.function.comm-interface"
            }
          }
        },
        {
          "name": "meta.parameter.declaration.comm-interface",
          "match": "\\b(in|out)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "support.type.param-direction.comm-interface"
            },
            "2": {
              "name": "storage.type.comm-interface"
            },
            "3": {
              "name": "variable.parameter"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.statement-kind.comm-interface",
          "match": "\\b(method)\\b"
        },
        {
          "name": "support.type.param-direction.comm-interface",
          "match": "\\b(in|out)\\b"
        },
        {
          "name": "storage.type.comm-interface",
          "match": "\\b(void|byte|bool|int|float|double|char|string)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.comm-interface",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.comm-interface",
          "match": "\\b[-+]?[0-9]*\\.[0-9]+([eE][-+]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.comm-interface",
          "match": "\\b[-+]?[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comm-interface",
          "match": "->"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.comm-interface",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.comm-interface",
          "match": ","
        },
        {
          "name": "punctuation.bracket.round.open.comm-interface",
          "match": "\\("
        },
        {
          "name": "punctuation.bracket.round.close.comm-interface",
          "match": "\\)"
        },
        {
          "name": "punctuation.bracket.square.open.comm-interface",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.square.close.comm-interface",
          "match": "\\]"
        },
        {
          "name": "punctuation.bracket.curly.open.comm-interface",
          "match": "\\{"
        },
        {
          "name": "punctuation.bracket.curly.close.comm-interface",
          "match": "\\}"
        }
      ]
    }
  },
  "scopeName": "source.comm-interface"
}